# Telemetry Dashboard UI - Environment Configuration
# Secrets marked with __PLACEHOLDER__ are injected at deploy time from terraform.tfvars

HOST=0.0.0.0
PORT=3000

# Runtime config injection (used by docker-entrypoint.sh to generate config.js via envsubst)
KEYCLOAK_URL=/auth
KEYCLOAK_REALM=oan-telemetry
KEYCLOAK_CLIENT_ID=oan-telemetry-dashboard
API_SERVER_URL=/api/telemetry/v1

# Keycloak Authentication (VITE_ vars are exposed to the client)
VITE_KEYCLOAK_URL=/auth
VITE_KEYCLOAK_REALM=oan-telemetry
VITE_KEYCLOAK_CLIENT_ID=oan-telemetry-dashboard

# Backend API
VITE_API_SERVER_URL=/api/telemetry/v1

# Environment
VITE_APP_ENV=development
VITE_DEBUG=true 